<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RentalApp"
             xmlns:converters="clr-namespace:RentalApp.Converters"
             x:Class="RentalApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available to all pages -->
            <converters:InvertedBoolConverter      x:Key="InvertedBoolConverter" />
            <converters:StringToBoolConverter      x:Key="StringToBoolConverter" />
            <converters:StatusColorConverter       x:Key="StatusColorConverter" />
            <converters:StatusIsRequestedConverter x:Key="StatusIsRequestedConverter" />
            <converters:StatusIsActiveConverter    x:Key="StatusIsActiveConverter" />
            <converters:StatusIsApprovedConverter  x:Key="StatusIsApprovedConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
